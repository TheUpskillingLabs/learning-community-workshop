# ---------------------------------------------------------------------------
# Copy to .env.local for local dev, and set the same keys in Vercel
# (Project → Settings → Environment Variables, Production + Preview).
#
# NEXT_PUBLIC_* vars are inlined into the browser bundle AT BUILD TIME.
# After changing a NEXT_PUBLIC_* value in Vercel you must REDEPLOY.
# ---------------------------------------------------------------------------

# --- Browser-readable (safe to expose; protected by RLS) --------------------
# Supabase project URL. Used by the big-screen Realtime client, and reused
# server-side by the admin client (a URL is not a secret).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co

# Supabase PUBLISHABLE key (new format: sb_publishable_...). Low-privilege,
# honors Row Level Security. In this app it is used ONLY to subscribe the big
# screens to Realtime Broadcast topics — it never reads or writes tables.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---------------------------
# Supabase SECRET key (new format: sb_secret_...). Bypasses RLS. The only
# credential that reads/writes tables and sends Broadcasts. Server-only.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Anthropic API key for the one-shot clustering call. Read automatically by
# `new Anthropic()`.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: override the clustering model (default claude-opus-4-8).
# claude-sonnet-5 is a cheaper/faster alternative that is fine for this task.
# CLUSTER_MODEL=claude-opus-4-8

# Shared facilitator password for /admin. Compared server-side with
# crypto.timingSafeEqual. Use a long random string. Rotate after the event.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Dedicated HMAC key used to sign the admin session cookie. Keep it separate
# from ADMIN_PASSWORD so the two rotate independently. If omitted, the app
# falls back to signing with ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=another-long-random-string
